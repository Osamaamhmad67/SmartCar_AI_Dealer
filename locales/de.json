    "info_header": "Informationen gemäß Art. 13 DSGVO / BDSG",
    "data_controller_title": "1. Verantwortlicher:",
    "data_controller_text": "Der Verantwortliche für die Verarbeitung Ihrer personenbezogenen Daten ist:",
