  "gdpr": {
    "section_title": "القسم 4: حماية البيانات الشخصية",
    "info_header": "معلومات وفقاً للمادة 13 من اللائحة العامة لحماية البيانات (GDPR) واللائحة الفيدرالية لحماية البيانات (BDSG)",
    "data_controller_title": "1. مسؤولية المعالجة:",
